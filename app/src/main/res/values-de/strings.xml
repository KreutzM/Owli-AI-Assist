    <string name="vlm_settings_openrouter_key_manage">Key verwalten</string>
    <string name="vlm_settings_openrouter_key_entry_helper">Oeffne den Transport-Bildschirm, um den Owli-Backend-Produktionspfad zu nutzen, auf direkten OpenRouter-BYOK zu wechseln oder den gespeicherten eigenen Key zu verwalten.</string>
