# Normalize text files to LF in the repository (prevents massive CRLF↔LF diffs)
* text=auto eol=lf

# Keep Windows batch scripts in CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Source / config files should be LF
*.kt   text eol=lf
*.kts  text eol=lf
*.java text eol=lf
*.xml  text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.properties text eol=lf
*.gradle text eol=lf
*.md   text eol=lf
*.txt  text eol=lf

# Binary files
*.png  binary
*.jpg  binary
*.jpeg binary
*.webp binary
*.gif  binary
*.tflite binary
*.so   binary
*.jar  binary
*.aar  binary

