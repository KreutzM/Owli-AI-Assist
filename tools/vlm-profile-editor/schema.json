{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VLM Profiles",
  "type": "object",
  "required": [
    "default_profile_id",
    "profiles"
  ],
  "additionalProperties": true,
  "properties": {
    "default_profile_id": {
      "type": "string",
      "minLength": 1
    },
    "defaults": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "provider": {
          "type": "string"
        },
        "system_prompt": {
          "type": "string"
        },
        "overview_prompt": {
          "type": "string"
        },
        "image": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "max_side_px": {
              "type": "number"
            },
            "jpeg_quality": {
              "type": "number"
            }
          }
        },
        "token_policy": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "max_tokens": {
              "type": "number"
            }
          }
        },
        "capabilities": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "supports_vision": {
              "type": "boolean"
            },
            "supports_reasoning": {
              "type": "boolean"
            },
            "supports_json": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "profiles": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/profile"
      }
    }
  },
  "$defs": {
    "profile": {
      "type": "object",
      "required": [
        "id",
        "label",
        "description",
        "model_id"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "model_id": {
          "type": "string",
          "minLength": 1
        },
        "provider": {
          "type": "string"
        },
        "family": {
          "type": "string"
        },
        "streaming_enabled": {
          "type": "boolean"
        },
        "system_prompt": {
          "type": "string"
        },
        "overview_prompt": {
          "type": "string"
        },
        "capabilities": {
          "$ref": "#/$defs/capabilities"
        },
        "parameter_overrides": {
          "$ref": "#/$defs/parameter_overrides"
        },
        "token_policy": {
          "$ref": "#/$defs/token_policy"
        },
        "auto_scan": {
          "$ref": "#/$defs/auto_scan"
        }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "supports_vision": {
          "type": "boolean"
        },
        "supports_reasoning": {
          "type": "boolean"
        },
        "supports_json": {
          "type": "boolean"
        }
      }
    },
    "parameter_overrides": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "temperature": {
          "type": "number"
        },
        "top_p": {
          "type": "number"
        }
      }
    },
    "token_policy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "max_tokens": {
          "type": "number"
        },
        "reasoning_effort": {
          "type": "string"
        },
        "reasoning_exclude": {
          "type": "boolean"
        },
        "retry1_max_tokens": {
          "type": "number"
        },
        "retry2_max_tokens": {
          "type": "number"
        }
      }
    },
    "auto_scan": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled_by_default": {
          "type": "boolean"
        },
        "interval_ms": {
          "type": "number"
        },
        "speak_free_every_ms": {
          "type": "number"
        }
      },
      "description": "Note: legacy key 'enabled' is not supported; use enabled_by_default."
    }
  }
}
