{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VLM Profile Registry",
  "type": "object",
  "required": [
    "schema_version",
    "default_profile_id",
    "profiles"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "const": "vlm_profile_registry/v1"
    },
    "default_profile_id": {
      "type": "string",
      "minLength": 1
    },
    "profiles": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/profile"
      }
    }
  },
  "$defs": {
    "profile": {
      "type": "object",
      "required": [
        "id",
        "label",
        "description",
        "availability"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "availability": {
          "enum": [
            "backend",
            "byok",
            "both"
          ]
        },
        "ui": {
          "$ref": "#/$defs/ui"
        },
        "backend": {
          "$ref": "#/$defs/backend"
        },
        "byok": {
          "$ref": "#/$defs/byok"
        },
        "debug": {
          "$ref": "#/$defs/debug"
        }
      }
    },
    "ui": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "group": { "type": "string" },
        "sort_order": { "type": "number" },
        "hidden": { "type": "boolean" },
        "badges": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "backend": {
      "type": "object",
      "required": [ "profile_id" ],
      "additionalProperties": true,
      "properties": {
        "profile_id": { "type": "string", "minLength": 1 },
        "supports_streaming": { "type": "boolean" },
        "supports_followup": { "type": "boolean" },
        "supports_followup_images": { "type": "boolean" },
        "notes": { "type": "string" }
      }
    },
    "byok": {
      "type": "object",
      "required": [ "provider", "model_id" ],
      "additionalProperties": true,
      "properties": {
        "provider": { "type": "string", "minLength": 1 },
        "model_id": { "type": "string", "minLength": 1 },
        "family": { "type": "string" },
        "streaming_enabled": { "type": "boolean" },
        "system_prompt": { "type": "string" },
        "overview_prompt": { "type": "string" },
        "capabilities": { "$ref": "#/$defs/capabilities" },
        "image": { "$ref": "#/$defs/image" },
        "token_policy": { "$ref": "#/$defs/token_policy" },
        "parameter_overrides": { "$ref": "#/$defs/parameter_overrides" },
        "auto_scan": { "$ref": "#/$defs/auto_scan" }
      }
    },
    "debug": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "embedded_key_allowed": { "type": "boolean" }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "supports_vision": { "type": "boolean" },
        "supports_reasoning": { "type": "boolean" },
        "supports_json": { "type": "boolean" }
      }
    },
    "image": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "max_side_px": { "type": "number" },
        "jpeg_quality": { "type": "number" },
        "detail": { "type": "string" }
      }
    },
    "token_policy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "max_tokens": { "type": "number" },
        "reasoning_effort": { "type": "string" },
        "reasoning_exclude": { "type": "boolean" },
        "retry1_max_tokens": { "type": "number" },
        "retry2_max_tokens": { "type": "number" }
      }
    },
    "parameter_overrides": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "temperature": { "type": "number" },
        "top_p": { "type": "number" },
        "reasoning_effort": { "type": "string" }
      }
    },
    "auto_scan": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled_by_default": { "type": "boolean" },
        "interval_ms": { "type": "number" },
        "speak_free_every_ms": { "type": "number" }
      }
    }
  }
}
